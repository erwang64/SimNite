<Application x:Class="SimNite.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:viewModels="clr-namespace:SimNite.ViewModels"
             xmlns:views="clr-namespace:SimNite.Views"
             xmlns:converters="clr-namespace:SimNite.Converters"
             StartupUri="MainWindow.xaml">
    <Application.Resources>
        <!-- Converters -->
        <converters:BoolToStepBackgroundConverter x:Key="BoolToStepBackgroundConverter"/>
        <converters:BoolToStepBorderConverter x:Key="BoolToStepBorderConverter"/>
        <converters:BoolToStepTextConverter x:Key="BoolToStepTextConverter"/>
        <converters:BoolToFontWeightConverter x:Key="BoolToFontWeightConverter"/>
        <converters:BoolToConnectorConverter x:Key="BoolToConnectorConverter"/>
        <converters:FileSizeConverter x:Key="FileSizeConverter"/>
        
        <!-- Dark theme palette (Lightened) -->
        <SolidColorBrush x:Key="SimNiteBackgroundBrush" Color="#1A1C23" />
        <SolidColorBrush x:Key="SimNiteSurfaceBrush" Color="#222530" />
        <SolidColorBrush x:Key="SimNitePanelBrush" Color="#2A2E3B" />
        <SolidColorBrush x:Key="SimNiteBorderBrush" Color="#383D4F" />
        <SolidColorBrush x:Key="SimNitePrimaryBrush" Color="#F7C614" />
        <SolidColorBrush x:Key="SimNiteTextBrush" Color="#E6E8EE" />
        <SolidColorBrush x:Key="SimNiteMutedBrush" Color="#B4B9C6" />
        <SolidColorBrush x:Key="SimNiteErrorBrush" Color="#FF6C6C" />
        <SolidColorBrush x:Key="SimNiteSuccessBrush" Color="#5AE890" />

        <SolidColorBrush x:Key="SimNiteInputBrush" Color="#1E212B" />
        <SolidColorBrush x:Key="SimNiteInputHoverBrush" Color="#242834" />
        <SolidColorBrush x:Key="SimNiteSelectionBrush" Color="#33F7C614" />
        <SolidColorBrush x:Key="SimNiteShadowBrush" Color="#66000000" />

        <Style TargetType="Window">
            <Setter Property="Background" Value="{StaticResource SimNiteBackgroundBrush}" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="TextOptions.TextFormattingMode" Value="Display" />
            <Setter Property="TextOptions.TextRenderingMode" Value="ClearType" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
        </Style>

        <Style x:Key="TitleTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="28" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
        </Style>

        <Style x:Key="SectionTextStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="20" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
        </Style>

        <Style TargetType="Border">
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
        </Style>

        <!-- Enhanced Button Styles with Animations -->
        <Style TargetType="Button">
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
            <Setter Property="Background" Value="{StaticResource SimNiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,8" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="buttonBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                SnapsToDevicePixels="True">
                            <ContentPresenter Margin="{TemplateBinding Padding}"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="{StaticResource SimNiteInputHoverBrush}" />
                                <Setter TargetName="buttonBorder" Property="BorderBrush" Value="#66F7C614" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="buttonBorder" Property="Background" Value="#1FF7C614" />
                                <Setter TargetName="buttonBorder" Property="BorderBrush" Value="{StaticResource SimNitePrimaryBrush}" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="buttonBorder" Property="Opacity" Value="0.55" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Background" Value="{StaticResource SimNitePrimaryBrush}" />
            <Setter Property="BorderBrush" Value="#D6AA10" />
            <Setter Property="Foreground" Value="#141414" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#F7C614" Opacity="0.3"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="NavButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
            <Setter Property="Padding" Value="16,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Background" Value="#0FF7C614" />
            <Setter Property="BorderBrush" Value="#33F7C614" />
        </Style>

        <!-- Enhanced Card Style -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource SimNitePanelBrush}" />
            <Setter Property="CornerRadius" Value="16" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="12" ShadowDepth="0" Color="#000000" Opacity="0.2"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <EventTrigger RoutedEvent="MouseEnter">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius"
                                             To="16" Duration="0:0:0.3"/>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity"
                                             To="0.3" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
                <EventTrigger RoutedEvent="MouseLeave">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.BlurRadius"
                                             To="12" Duration="0:0:0.3"/>
                            <DoubleAnimation Storyboard.TargetProperty="Effect.Opacity"
                                             To="0.2" Duration="0:0:0.3"/>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Modern TextBox Style -->
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="{StaticResource SimNiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="SelectionBrush" Value="{StaticResource SimNiteSelectionBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="border"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="false"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource SimNitePrimaryBrush}" />
                                <Setter TargetName="border" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="0" Color="#F7C614" Opacity="0.3"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="{StaticResource SimNiteInputBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="6,4" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
        </Style>

        <Style TargetType="ProgressBar">
            <Setter Property="Foreground" Value="{StaticResource SimNitePrimaryBrush}" />
            <Setter Property="Background" Value="{StaticResource SimNiteInputBrush}" />
            <Setter Property="Height" Value="20" />
        </Style>

        <Style TargetType="DataGrid">
            <Setter Property="Background" Value="{StaticResource SimNiteSurfaceBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HorizontalGridLinesBrush" Value="#1FFFFFFF" />
            <Setter Property="VerticalGridLinesBrush" Value="#1FFFFFFF" />
            <Setter Property="RowBackground" Value="#111521" />
            <Setter Property="AlternatingRowBackground" Value="#151B2A" />
            <Setter Property="HeadersVisibility" Value="Column" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
        </Style>

        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background" Value="#111521" />
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource SimNiteBorderBrush}" />
            <Setter Property="BorderThickness" Value="0,0,0,1" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <Style TargetType="DataGridRow">
            <Setter Property="Foreground" Value="{StaticResource SimNiteTextBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#22F7C614" />
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type viewModels:WelcomeViewModel}">
            <views:WelcomeView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:ModListViewModel}">
            <views:ModListView />
        </DataTemplate>

        <DataTemplate DataType="{x:Type viewModels:InstallViewModel}">
            <views:InstallView />
        </DataTemplate>


        <DataTemplate DataType="{x:Type viewModels:SettingsViewModel}">
            <views:SettingsView />
        </DataTemplate>

    </Application.Resources>
</Application>
