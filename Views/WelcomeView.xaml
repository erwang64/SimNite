<UserControl x:Class="SimNite.Views.WelcomeView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Background="{StaticResource SimNiteBackgroundBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- Hero Section -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
            <StackPanel Margin="40,60,40,40" HorizontalAlignment="Center">
                
                <!-- Logo et Titre -->
                <StackPanel HorizontalAlignment="Center" Margin="0,0,0,40">
                    <Image Width="120"
                           Height="120"
                           Margin="0,0,0,20"
                           Source="/Logo/SimNite_icon.png"
                           Stretch="Uniform">
                        <Image.Effect>
                            <DropShadowEffect BlurRadius="20" ShadowDepth="0" Color="#F7C614" Opacity="0.3"/>
                        </Image.Effect>
                    </Image>
                    <TextBlock Text="SimNite" 
                               FontSize="48" 
                               FontWeight="Bold" 
                               Foreground="{StaticResource SimNiteTextBrush}"
                               HorizontalAlignment="Center"
                               FontFamily="Segoe UI Variable">
                        <TextBlock.Effect>
                            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Color="#000000" Opacity="0.5"/>
                        </TextBlock.Effect>
                    </TextBlock>
                    <TextBlock Text="Votre gestionnaire de mods MSFS" 
                               FontSize="18" 
                               Foreground="{StaticResource SimNiteMutedBrush}"
                               HorizontalAlignment="Center"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <!-- Cartes d'introduction -->
                <StackPanel MaxWidth="800" HorizontalAlignment="Center">
                    
                    <!-- Carte 1: Bienvenue -->
                    <Border Background="{StaticResource SimNitePanelBrush}"
                            CornerRadius="16"
                            Padding="30"
                            Margin="0,0,0,20"
                            BorderBrush="{StaticResource SimNiteBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="👋 Bienvenue dans SimNite" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SimNitePrimaryBrush}"
                                       Margin="0,0,0,15"/>
                            <TextBlock Text="SimNite est la solution moderne pour gérer facilement vos mods Microsoft Flight Simulator. Fini les installations manuelles fastidieuses !" 
                                       FontSize="16"
                                       LineHeight="24"
                                       TextWrapping="Wrap"
                                       Foreground="{StaticResource SimNiteTextBrush}"/>
                        </StackPanel>
                    </Border>

                    <!-- Carte 2: Fonctionnalités -->
                    <Border Background="{StaticResource SimNitePanelBrush}"
                            CornerRadius="16"
                            Padding="30"
                            Margin="0,0,0,20"
                            BorderBrush="{StaticResource SimNiteBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="✨ Fonctionnalités principales" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SimNitePrimaryBrush}"
                                       Margin="0,0,0,15"/>
                            <StackPanel>
                                <TextBlock Text="📦 **Catalogue complet** - Accédez à une vaste bibliothèque de mods vérifiés" 
                                           FontSize="16"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SimNiteTextBrush}"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="⚡ **Installation rapide** - Installez tous vos mods en un seul clic" 
                                           FontSize="16"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SimNiteTextBrush}"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="🎯 **Gestion intelligente** - Organisez vos mods par profils et préférences" 
                                           FontSize="16"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SimNiteTextBrush}"
                                           Margin="0,0,0,10"/>
                                <TextBlock Text="🔄 **Mises à jour automatiques** - Gardez vos mods toujours à jour" 
                                           FontSize="16"
                                           LineHeight="24"
                                           TextWrapping="Wrap"
                                           Foreground="{StaticResource SimNiteTextBrush}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

                    <!-- Carte 3: Comment ça marche -->
                    <Border Background="{StaticResource SimNitePanelBrush}"
                            CornerRadius="16"
                            Padding="30"
                            Margin="0,0,0,20"
                            BorderBrush="{StaticResource SimNiteBorderBrush}"
                            BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="🚀 Comment ça marche ?" 
                                       FontSize="24" 
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SimNitePrimaryBrush}"
                                       Margin="0,0,0,15"/>
                            <StackPanel>
                                <Border Background="{StaticResource SimNiteSurfaceBrush}"
                                        CornerRadius="12"
                                        Padding="20"
                                        Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource SimNitePrimaryBrush}"
                                                Width="40"
                                                Height="40"
                                                CornerRadius="20"
                                                Margin="0,0,15,0">
                                            <TextBlock Text="1" 
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#141414"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Explorez le catalogue" 
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SimNiteTextBrush}"/>
                                            <TextBlock Text="Découvrez les mods disponibles" 
                                                       FontSize="14"
                                                       Foreground="{StaticResource SimNiteMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource SimNiteSurfaceBrush}"
                                        CornerRadius="12"
                                        Padding="20"
                                        Margin="0,0,0,15">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource SimNitePrimaryBrush}"
                                                Width="40"
                                                Height="40"
                                                CornerRadius="20"
                                                Margin="0,0,15,0">
                                            <TextBlock Text="2" 
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#141414"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Sélectionnez et installez" 
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SimNiteTextBrush}"/>
                                            <TextBlock Text="Choisissez vos mods préférés" 
                                                       FontSize="14"
                                                       Foreground="{StaticResource SimNiteMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>

                                <Border Background="{StaticResource SimNiteSurfaceBrush}"
                                        CornerRadius="12"
                                        Padding="20">
                                    <StackPanel Orientation="Horizontal">
                                        <Border Background="{StaticResource SimNitePrimaryBrush}"
                                                Width="40"
                                                Height="40"
                                                CornerRadius="20"
                                                Margin="0,0,15,0">
                                            <TextBlock Text="3" 
                                                       FontSize="20"
                                                       FontWeight="Bold"
                                                       Foreground="#141414"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Border>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="Volez ! 🛩️" 
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       Foreground="{StaticResource SimNiteTextBrush}"/>
                                            <TextBlock Text="Profitez de votre expérience MSFS améliorée" 
                                                       FontSize="14"
                                                       Foreground="{StaticResource SimNiteMutedBrush}"/>
                                        </StackPanel>
                                    </StackPanel>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>

        <!-- Bouton d'action -->
        <Border Grid.Row="1" 
                Background="{StaticResource SimNitePanelBrush}"
                Padding="30"
                BorderBrush="{StaticResource SimNiteBorderBrush}"
                BorderThickness="0,1,0,0">
            <StackPanel HorizontalAlignment="Center">
                <Button Command="{Binding StartJourneyCommand}"
                        Style="{StaticResource PrimaryButtonStyle}"
                        Padding="40,20"
                        FontSize="18"
                        FontWeight="SemiBold">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="Commencer l'aventure " Margin="0,0,10,0"/>
                        <TextBlock Text="→"/>
                    </StackPanel>
                </Button>
                <TextBlock Text="Prêt à transformer votre expérience MSFS ?" 
                           FontSize="14"
                           Foreground="{StaticResource SimNiteMutedBrush}"
                           HorizontalAlignment="Center"
                           Margin="0,10,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
