<UserControl x:Class="SimNite.Views.SimulatorSettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10" HorizontalAlignment="Center">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Margin="0,0,0,12" Style="{StaticResource TitleTextStyle}" Text="Simulator Settings Backup" HorizontalAlignment="Center" />

        <Grid Grid.Row="1" Margin="0,0,0,16">
            <StackPanel MaxWidth="800" HorizontalAlignment="Center">
                <!-- Backup Section -->
                <Border Padding="24" Background="{StaticResource SimNitePanelBrush}" CornerRadius="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Backup UserCfg.opt" Foreground="{StaticResource SimNiteTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Back up your simulator settings (graphics + options) into a ZIP archive."
                                   Foreground="{StaticResource SimNiteMutedBrush}" TextWrapping="Wrap" FontSize="14" LineHeight="24" Margin="0,0,0,24"/>

                        <TextBlock Text="MSFS UserCfg.opt Source File" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding UserCfgPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            </Border>

                            <Button Grid.Column="1" Command="{Binding BrowseUserCfgCommand}" Content="📁 Browse" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <TextBlock Text="Backup Destination Folder" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding BackupDestinationPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            </Border>

                            <Button Grid.Column="1" Command="{Binding BrowseBackupPathCommand}" Content="📁 Browse" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding BackupCommand}" Content="Create Backup ZIP" Height="44" FontSize="15" HorizontalAlignment="Center" Padding="32,0" />
                    </StackPanel>
                </Border>

                <!-- Restore Section -->
                <Border Padding="24" Background="{StaticResource SimNitePanelBrush}" CornerRadius="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Restore UserCfg.opt" Foreground="{StaticResource SimNiteTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Reinject your settings back into MSFS from an existing ZIP backup."
                                   Foreground="{StaticResource SimNiteMutedBrush}" TextWrapping="Wrap" FontSize="14" LineHeight="24" Margin="0,0,0,24"/>

                        <TextBlock Text="Backup ZIP File" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding RestoreZipPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            </Border>

                            <Button Grid.Column="1" Command="{Binding BrowseRestoreZipCommand}" Content="📁 Browse File" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Button Command="{Binding RestoreCommand}" Content="Restore into MSFS" Height="44" FontSize="15" HorizontalAlignment="Center" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" Foreground="{StaticResource SimNiteTextBrush}" Padding="32,0" />

                        <TextBlock Text="Tip: close Microsoft Flight Simulator before restoring." Foreground="{StaticResource SimNiteMutedBrush}" TextWrapping="Wrap" FontSize="12" Margin="0,16,0,0" />
                    </StackPanel>
                </Border>

                <!-- Status Feedback -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SimNitePrimaryBrush}" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>

