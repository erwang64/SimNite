<UserControl x:Class="SimNite.Views.ModListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="#0B0B0C">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- Main Content -->
        <Border Grid.Column="0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="Auto" /> <!-- Tabs -->
                    <RowDefinition Height="*" /> <!-- List -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Bibliothèque de mods" FontSize="24" FontWeight="Bold" Foreground="White" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Background="#1C1C1C" CornerRadius="12" Margin="12,0,0,0" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="1 mods" FontSize="12" Foreground="#888888"/>
                    </Border>
                    
                    <!-- Search -->
                    <Border Grid.Column="3" Background="#1C1C1C" CornerRadius="8" BorderBrush="#333333" BorderThickness="1" Margin="0,0,12,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="#AAAAAA" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBox Width="220" Background="Transparent" BorderThickness="0" Foreground="White" FontSize="14" Text="Rechercher un mod..." VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tabs -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Background="#F7C614" CornerRadius="4" Padding="16,6" Margin="0,0,8,0">
                        <TextBlock Text="Tous" Foreground="Black" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <TextBlock Text="Avions   1" Foreground="#AAAAAA" FontSize="14" VerticalAlignment="Center" Margin="12,0,12,0"/>
                    <TextBlock Text="Livrées   0" Foreground="#AAAAAA" FontSize="14" VerticalAlignment="Center" Margin="12,0,12,0"/>
                </StackPanel>

                <!-- List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Group Header -->
                        <TextBlock Text="AVIONS (1)" Foreground="#3A5B8A" FontWeight="Bold" FontSize="12" Margin="0,0,0,12"/>
                        
                        <!-- List of Mods -->
                        <ItemsControl ItemsSource="{Binding FilteredMods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" BorderBrush="#1C1C1C" BorderThickness="0,0,0,1" Padding="0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" VerticalAlignment="Top" Margin="0,4,16,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <!-- Details -->
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Version}" Foreground="#666666" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding Description}" Foreground="#AAAAAA" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Category Tag -->
                                                    <Border Background="#1A2536" CornerRadius="4" Padding="8,2" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Category}" Foreground="#5A8ECC" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    
                                                    <TextBlock Text="💾" Foreground="#666666" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding SizeBytes}" Foreground="#888888" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    
                                                    <TextBlock Text="par " Foreground="#666666" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Author}" Foreground="#888888" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Install Mode Badge -->
                                            <Border Grid.Column="2" Background="#112A1F" BorderBrush="#1C4C34" BorderThickness="1" CornerRadius="4" Padding="8,4" VerticalAlignment="Top">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚡" Foreground="#4ADE80" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Auto" Foreground="#4ADE80" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right Sidebar (Sélection) -->
        <Border Grid.Column="1" Background="#111111" BorderBrush="#1C1C1C" BorderThickness="1,0,0,0" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Sélection" Foreground="White" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="Tout" Foreground="#AAAAAA" FontSize="12" Margin="0,0,8,0" Cursor="Hand"/>
                    <TextBlock Grid.Column="2" Text="Aucun" Foreground="#AAAAAA" FontSize="12" Cursor="Hand"/>
                </Grid>

                <!-- Selected List (Placeholder for now) -->
                <TextBlock Grid.Row="1" Text="Coche des mods dans la liste pour les ajouter à ta sélection" Foreground="#666666" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" Margin="0,40,0,0"/>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="0 mods sélectionnés" Foreground="#888888" FontSize="12" Margin="0,0,0,12"/>
                    <Button Content="Exporter en profil" Background="#151515" Foreground="#666666" BorderBrush="#222222" BorderThickness="1" Padding="0,12" FontSize="14" Margin="0,0,0,12"/>
                    <Button Content="Installer la sélection" Background="#151515" Foreground="#666666" BorderBrush="#222222" BorderThickness="1" Padding="0,12" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
