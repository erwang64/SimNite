<UserControl x:Class="SimNite.Views.ModListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource SimNiteBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- Main Content -->
        <Border Grid.Column="0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="Auto" /> <!-- Tabs -->
                    <RowDefinition Height="*" /> <!-- List -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Mods Library" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SimNiteTextBrush}" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Background="{StaticResource SimNiteSurfaceBrush}" CornerRadius="12" Margin="12,0,0,0" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="{Binding FilteredMods.Count, StringFormat='{}{0} mods'}" FontSize="12" Foreground="{StaticResource SimNiteMutedBrush}"/>
                    </Border>
                    
                    <!-- Search -->
                    <Border Grid.Column="3" Background="{StaticResource SimNiteInputBrush}" CornerRadius="16" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Margin="0,0,12,0" Padding="16,6">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,12,0" FontSize="14" VerticalAlignment="Center"/>
                            <Grid>
                                <TextBlock Text="Search for a mod..." Foreground="{StaticResource SimNiteMutedBrush}" FontSize="13" VerticalAlignment="Center" IsHitTestVisible="False">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Text.Length, ElementName=SearchBox}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <TextBox x:Name="SearchBox" Width="200" Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" FontSize="13" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tabs Area (Removed static mock tabs to favor Expanders) -->

                <!-- List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <ItemsControl ItemsSource="{Binding GroupedMods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Expander IsExpanded="True" Margin="0,0,0,24" Background="Transparent" BorderThickness="0">
                                    <Expander.Header>
                                        <TextBlock Text="{Binding Key}" Foreground="{StaticResource SimNitePrimaryBrush}" FontWeight="Bold" FontSize="14" Margin="0,0,0,8"/>
                                    </Expander.Header>
                                    <ItemsControl ItemsSource="{Binding}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Background="Transparent" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,0,0,1" Padding="0,16">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                        </Grid.ColumnDefinitions>

                                                        <!-- Checkbox -->
                                                        <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" VerticalAlignment="Center" Margin="0,0,16,0">
                                                            <CheckBox.LayoutTransform>
                                                                <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                                            </CheckBox.LayoutTransform>
                                                        </CheckBox>

                                                        <!-- Image Preview -->
                                                        <Border Grid.Column="1" Width="80" Height="60" CornerRadius="8" Background="{StaticResource SimNiteSurfaceBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Margin="0,0,16,0" VerticalAlignment="Center">
                                                            <Border.Clip>
                                                                <RectangleGeometry RadiusX="8" RadiusY="8" Rect="0,0,80,60" />
                                                            </Border.Clip>
                                                            <!-- If ImageUrl is null, fallback to transparent/empty box via WPF default behavior -->
                                                            <Image Source="{Binding ImageUrl}" Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        </Border>

                                                        <!-- Details -->
                                                        <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                                <TextBlock Text="{Binding Name}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                                <TextBlock Text="{Binding Version}" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                            </StackPanel>
                                                            
                                                            <TextBlock Text="{Binding Description}" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                            
                                                            <StackPanel Orientation="Horizontal">
                                                                <!-- Category Tag -->
                                                                <Border Background="{StaticResource SimNiteSurfaceBrush}" CornerRadius="4" Padding="8,2" Margin="0,0,12,0">
                                                                    <TextBlock Text="{Binding Category}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                                </Border>
                                                                
                                                                <TextBlock Text="💾" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding SizeBytes}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                                
                                                                <TextBlock Text="by " Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                                <TextBlock Text="{Binding Author}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Expander>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right Sidebar (Sélection) -->
        <Border Grid.Column="1" Background="{StaticResource SimNiteSurfaceBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1,0,0,0" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Selection" Foreground="{StaticResource SimNiteTextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="All" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" Margin="0,0,8,0" Cursor="Hand"/>
                    <TextBlock Grid.Column="2" Text="None" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" Cursor="Hand"/>
                </Grid>

                <!-- Selected List -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,20,0,20">
                    <ItemsControl ItemsSource="{Binding SelectedMods}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="13" TextTrimming="CharacterEllipsis"/>
                                    <!-- Simple indicator, no remove command for now as toggling via main list suffices -->
                                    <TextBlock Grid.Column="1" Text="✓" Foreground="{StaticResource SimNiteSuccessBrush}" FontSize="14" Margin="8,0,0,0"/>
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                        
                        <!-- Empty Template fallback could be added via triggers, but keep simple -->
                    </ItemsControl>
                </ScrollViewer>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="{Binding SelectedMods.Count, StringFormat='{}{0} mods selected'}" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" Margin="0,0,0,12"/>
                    <Button Content="Export to profile" Background="{StaticResource SimNiteInputBrush}" Foreground="{StaticResource SimNiteTextBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Padding="0,12" FontSize="14" Margin="0,0,0,12"/>
                    <Button Content="Install selection" Command="{Binding InstallSelectionCommand}" Background="{StaticResource SimNiteInputBrush}" Foreground="{StaticResource SimNiteTextBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Padding="0,12" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
