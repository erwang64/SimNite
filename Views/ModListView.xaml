<UserControl x:Class="SimNite.Views.ModListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0"
                   Margin="6,0,0,12"
                   Style="{StaticResource TitleTextStyle}"
                   Text="Catalogue des mods" />

        <Border Grid.Row="1" Padding="14" Margin="0,0,0,12" Background="{StaticResource SimNitePanelBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="200" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,0,6" Foreground="{StaticResource SimNiteMutedBrush}" Text="Recherche" />
                <TextBlock Grid.Row="0" Grid.Column="1" Margin="12,0,0,6" Foreground="{StaticResource SimNiteMutedBrush}" Text="Categorie" />

                <TextBox Grid.Row="1"
                         Grid.Column="0"
                         Height="36"
                         Margin="0,0,12,0"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

                <ComboBox Grid.Row="1"
                          Grid.Column="1"
                          Height="36"
                          Margin="0,0,12,0"
                          ItemsSource="{Binding Categories}"
                          SelectedItem="{Binding SelectedCategory}" />

                <StackPanel Grid.Row="0" Grid.RowSpan="2" Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Bottom">
                    <Button Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding LoadModsCommand}" Content="Charger" />
                    <Button Margin="0,0,8,0" Command="{Binding RefreshModsCommand}" Content="Rafraichir" />
                    <Button Margin="0,0,8,0" Command="{Binding ClearFiltersCommand}" Content="Effacer" />
                    <Button Command="{Binding CancelLoadCommand}" Content="Annuler" />
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Margin="0,0,0,8"
                       Foreground="{StaticResource SimNiteErrorBrush}"
                       FontWeight="SemiBold"
                       Text="{Binding ErrorMessage}" />

            <Border Grid.Row="1" Background="{StaticResource SimNiteSurfaceBrush}" Padding="0">
                <DataGrid AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          IsReadOnly="False"
                          ItemsSource="{Binding FilteredMods}">
                    <DataGrid.Columns>
                        <DataGridCheckBoxColumn Width="70" Header="Use" Binding="{Binding IsChecked}" />
                        <DataGridTextColumn Width="2*" Header="Nom" Binding="{Binding Name}" IsReadOnly="True" />
                        <DataGridTextColumn Width="*" Header="Categorie" Binding="{Binding Category}" IsReadOnly="True" />
                        <DataGridTextColumn Width="*" Header="Type" Binding="{Binding Type}" IsReadOnly="True" />
                        <DataGridTextColumn Width="*" Header="Mode" Binding="{Binding InstallMode}" IsReadOnly="True" />
                        <DataGridTextColumn Width="*" Header="Version" Binding="{Binding Version}" IsReadOnly="True" />
                        <DataGridTextColumn Width="*" Header="Taille (bytes)" Binding="{Binding SizeBytes}" IsReadOnly="True" />
                    </DataGrid.Columns>
                </DataGrid>
            </Border>
        </Grid>
    </Grid>
</UserControl>

