<UserControl x:Class="SimNite.Views.ModListView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource SimNiteBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="260" />
        </Grid.ColumnDefinitions>

        <!-- Main Content -->
        <Border Grid.Column="0" Padding="30">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" /> <!-- Header -->
                    <RowDefinition Height="Auto" /> <!-- Tabs -->
                    <RowDefinition Height="*" /> <!-- List -->
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Grid.Row="0" Margin="0,0,0,20">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    
                    <TextBlock Grid.Column="0" Text="Mods Library" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SimNiteTextBrush}" VerticalAlignment="Center" />
                    <Border Grid.Column="1" Background="{StaticResource SimNiteSurfaceBrush}" CornerRadius="12" Margin="12,0,0,0" Padding="8,4" VerticalAlignment="Center">
                        <TextBlock Text="1 mods" FontSize="12" Foreground="{StaticResource SimNiteMutedBrush}"/>
                    </Border>
                    
                    <!-- Search -->
                    <Border Grid.Column="3" Background="{StaticResource SimNiteInputBrush}" CornerRadius="8" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Margin="0,0,12,0" Padding="12,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="🔍" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,8,0" FontSize="14" VerticalAlignment="Center"/>
                            <TextBox Width="220" Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" FontSize="14" Text="Search for a mod..." VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                </Grid>

                <!-- Tabs -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
                    <Border Background="{StaticResource SimNitePrimaryBrush}" CornerRadius="4" Padding="16,6" Margin="0,0,8,0">
                        <TextBlock Text="All" Foreground="#141414" FontWeight="Bold" FontSize="14"/>
                    </Border>
                    <TextBlock Text="Aircraft   1" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="12,0,12,0"/>
                    <TextBlock Text="Liveries   0" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="14" VerticalAlignment="Center" Margin="12,0,12,0"/>
                </StackPanel>

                <!-- List -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>
                        <!-- Group Header -->
                        <TextBlock Text="AIRCRAFT (1)" Foreground="{StaticResource SimNitePrimaryBrush}" FontWeight="Bold" FontSize="12" Margin="0,0,0,12"/>
                        
                        <!-- List of Mods -->
                        <ItemsControl ItemsSource="{Binding FilteredMods}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="Transparent" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,0,0,1" Padding="0,16">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Checkbox -->
                                            <CheckBox Grid.Column="0" IsChecked="{Binding IsChecked}" VerticalAlignment="Top" Margin="0,4,16,0">
                                                <CheckBox.LayoutTransform>
                                                    <ScaleTransform ScaleX="1.2" ScaleY="1.2"/>
                                                </CheckBox.LayoutTransform>
                                            </CheckBox>

                                            <!-- Details -->
                                            <StackPanel Grid.Column="1">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                                    <TextBlock Text="{Binding Name}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="16" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                                    <TextBlock Text="{Binding Version}" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                                                </StackPanel>
                                                
                                                <TextBlock Text="{Binding Description}" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="13" Margin="0,0,0,8" TextWrapping="Wrap"/>
                                                
                                                <StackPanel Orientation="Horizontal">
                                                    <!-- Category Tag -->
                                                    <Border Background="{StaticResource SimNiteSurfaceBrush}" CornerRadius="4" Padding="8,2" Margin="0,0,12,0">
                                                        <TextBlock Text="{Binding Category}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="11" FontWeight="SemiBold"/>
                                                    </Border>
                                                    
                                                    <TextBlock Text="💾" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,4,0"/>
                                                    <TextBlock Text="{Binding SizeBytes}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                                    
                                                    <TextBlock Text="by " Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding Author}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="12" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </StackPanel>

                                            <!-- Install Mode Badge -->
                                            <Border Grid.Column="2" Background="#1F5AE890" BorderBrush="{StaticResource SimNiteSuccessBrush}" BorderThickness="1" CornerRadius="4" Padding="8,4" VerticalAlignment="Top">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="⚡" Foreground="{StaticResource SimNiteSuccessBrush}" FontSize="10" Margin="0,0,4,0" VerticalAlignment="Center"/>
                                                    <TextBlock Text="Auto" Foreground="{StaticResource SimNiteSuccessBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- Right Sidebar (Sélection) -->
        <Border Grid.Column="1" Background="{StaticResource SimNiteSurfaceBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1,0,0,0" Padding="24">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Margin="0,0,0,24">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="Selection" Foreground="{StaticResource SimNiteTextBrush}" FontSize="18" FontWeight="SemiBold"/>
                    <TextBlock Grid.Column="1" Text="All" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" Margin="0,0,8,0" Cursor="Hand"/>
                    <TextBlock Grid.Column="2" Text="None" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" Cursor="Hand"/>
                </Grid>

                <!-- Selected List (Placeholder for now) -->
                <TextBlock Grid.Row="1" Text="Check mods in the list to add them to your selection" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="13" TextWrapping="Wrap" TextAlignment="Center" Margin="0,40,0,0"/>

                <!-- Bottom Actions -->
                <StackPanel Grid.Row="2">
                    <TextBlock Text="0 mods selected" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" Margin="0,0,0,12"/>
                    <Button Content="Export to profile" Background="{StaticResource SimNiteInputBrush}" Foreground="{StaticResource SimNiteTextBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Padding="0,12" FontSize="14" Margin="0,0,0,12"/>
                    <Button Content="Install selection" Background="{StaticResource SimNiteInputBrush}" Foreground="{StaticResource SimNiteTextBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" Padding="0,12" FontSize="14"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
