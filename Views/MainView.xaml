<UserControl x:Class="SimNite.Views.MainView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Background="{StaticResource SimNiteBackgroundBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- Sidebar -->
        <Border Grid.Column="0" Background="{StaticResource SimNiteSurfaceBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Background="White" Margin="0,0,0,32" Padding="0,40,0,30" CornerRadius="0">
                    <Button Command="{Binding ShowWelcomeCommand}" Background="Transparent" BorderThickness="0" Cursor="Hand" HorizontalAlignment="Stretch">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </ControlTemplate>
                        </Button.Template>
                        <Image Source="/Logo/LogoFull.png" Stretch="Uniform" Height="140" HorizontalAlignment="Center" Margin="10,0,10,0"/>
                    </Button>
                </Border>

                <!-- Navigation -->
                <StackPanel Grid.Row="1" Margin="20,10,20,0">
                    <StackPanel.Resources>
                        <Style x:Key="NavButtonStyle" TargetType="Button">
                            <Setter Property="Background" Value="Transparent" />
                            <Setter Property="BorderThickness" Value="0" />
                            <Setter Property="Foreground" Value="{StaticResource SimNiteMutedBrush}" />
                            <Setter Property="Padding" Value="24,16" />
                            <Setter Property="Margin" Value="0,0,0,12" />
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="{StaticResource SimNiteInputHoverBrush}" />
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Resources>

                    <!-- Mods -->
                    <Button Command="{Binding ShowModListCommand}" Padding="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsModListActive}" Value="True">
                                        <Setter Property="Background" Value="#1FF7C614" />
                                        <Setter Property="BorderBrush" Value="{StaticResource SimNitePrimaryBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="{StaticResource SimNitePrimaryBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Width="220">
                            <TextBlock Text="📦" Margin="0,0,16,0" FontSize="22"/>
                            <TextBlock Text="Mods" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Téléchargements -->
                    <Button Command="{Binding ShowInstallCommand}" Padding="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsInstallActive}" Value="True">
                                        <Setter Property="Background" Value="#1FF7C614" />
                                        <Setter Property="BorderBrush" Value="{StaticResource SimNitePrimaryBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="{StaticResource SimNitePrimaryBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Width="220">
                            <TextBlock Text="⬇️" Margin="0,0,16,0" FontSize="22"/>
                            <TextBlock Text="Downloads" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Paramètres -->
                    <Button Command="{Binding ShowSettingsCommand}" Padding="0">
                        <Button.Style>
                            <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsActive}" Value="True">
                                        <Setter Property="Background" Value="#1FF7C614" />
                                        <Setter Property="BorderBrush" Value="{StaticResource SimNitePrimaryBrush}" />
                                        <Setter Property="BorderThickness" Value="1" />
                                        <Setter Property="Foreground" Value="{StaticResource SimNitePrimaryBrush}" />
                                        <Setter Property="FontWeight" Value="SemiBold" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Button.Style>
                        <StackPanel Orientation="Horizontal" Width="220">
                            <TextBlock Text="⚙️" Margin="0,0,16,0" FontSize="22"/>
                            <TextBlock Text="Settings" FontSize="18" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Footer Community Folder & Version -->
                <StackPanel Grid.Row="2" Margin="20,0,20,32">
                    <Border Padding="16" Background="{StaticResource SimNitePanelBrush}" BorderThickness="1" BorderBrush="{StaticResource SimNiteBorderBrush}" Margin="0,0,0,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📁" Margin="0,0,16,0" VerticalAlignment="Center" FontSize="20"/>
                            <StackPanel>
                                <TextBlock Text="Community Folder" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="14"/>
                                <TextBlock Text="{Binding SettingsViewModel.CommunityFolderPath}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="12" TextTrimming="CharacterEllipsis" MaxWidth="180"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    
                    <TextBlock Text="SimNite v0.1" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="12" HorizontalAlignment="Center" Opacity="0.5"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Content Area -->
        <Border Grid.Column="1" Background="{StaticResource SimNiteBackgroundBrush}">
            <ContentControl Content="{Binding CurrentViewModel}" />
        </Border>
    </Grid>
</UserControl>
