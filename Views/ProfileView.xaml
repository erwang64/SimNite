<UserControl x:Class="SimNite.Views.ProfileView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Margin="6,0,0,12" Style="{StaticResource TitleTextStyle}" Text="Profils" />

        <Border Grid.Row="1" Padding="16" Background="White">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="180" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Foreground="{StaticResource SimNiteMutedBrush}" Text="Nom du profil" />
                <TextBox Grid.Row="0" Grid.Column="1" Height="36" Margin="0,0,0,8" Text="{Binding ProfileName, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Foreground="{StaticResource SimNiteMutedBrush}" Text="Fichier profil" />
                <TextBox Grid.Row="1" Grid.Column="1" Height="36" Margin="0,0,0,8" Text="{Binding ProfilePath, UpdateSourceTrigger=PropertyChanged}" />

                <TextBlock Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" Foreground="{StaticResource SimNiteMutedBrush}" Text="Community Folder" />
                <TextBox Grid.Row="2" Grid.Column="1" Height="36" Margin="0,0,0,8" Text="{Binding CommunityFolderPath, UpdateSourceTrigger=PropertyChanged}" />

                <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,6,0,0">
                    <Button Margin="0,0,8,0" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveProfileCommand}" Content="Sauvegarder" />
                    <Button Margin="0,0,8,0" Command="{Binding LoadProfileCommand}" Content="Charger" />
                    <Button Command="{Binding ScanCommunityCommand}" Content="Scanner Community" />
                </StackPanel>
            </Grid>
        </Border>

        <TextBlock Grid.Row="1"
                   Margin="16,0,16,16"
                   VerticalAlignment="Bottom"
                   Foreground="{StaticResource SimNiteSuccessBrush}"
                   FontWeight="SemiBold"
                   Text="{Binding StatusMessage}" />
    </Grid>
</UserControl>

