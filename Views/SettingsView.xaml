<UserControl x:Class="SimNite.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Margin="6,0,0,12" Style="{StaticResource TitleTextStyle}" Text="Settings" />

        <Grid Grid.Row="1" Margin="6,0,6,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="20" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- App Configuration -->
            <Border Grid.Column="0" Padding="24" Background="{StaticResource SimNitePanelBrush}" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Application Settings" Foreground="{StaticResource SimNiteTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,24" />

                    <TextBlock Text="Settings File Location" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                    <Border Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6" Height="40" Margin="0,0,0,16">
                        <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding SettingsPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                    </Border>

                    <TextBlock Text="Max Concurrent Downloads" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                    <Border Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6" Height="40" Margin="0,0,0,32">
                        <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=PropertyChanged}" />
                    </Border>

                    <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding SaveSettingsCommand}" Content="Save Changes" Height="40" FontSize="14" Margin="0,0,0,8"/>
                    <Button Command="{Binding LoadSettingsCommand}" Content="Reload Settings" Height="40" FontSize="14" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" Foreground="{StaticResource SimNiteTextBrush}"/>
                </StackPanel>
            </Border>

            <!-- Paths Configuration -->
            <Border Grid.Column="2" Padding="24" Background="{StaticResource SimNitePanelBrush}" CornerRadius="12">
                <StackPanel>
                    <TextBlock Text="Folders &amp; Paths" Foreground="{StaticResource SimNiteTextBrush}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <TextBlock Text="Manage where your mods and temporary files go." Foreground="{StaticResource SimNiteMutedBrush}" TextWrapping="Wrap" Margin="0,0,0,24" />

                    <TextBlock Text="Community Folder" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                            <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding CommunityFolderPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        </Border>
                        <Button Grid.Column="1" Command="{Binding BrowseCommunityFolderCommand}" Content="📁 Browse" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>
                    <Button Command="{Binding DetectCommunityFolderCommand}" Content="Auto-Detect Community Folder" HorizontalAlignment="Left" Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNitePrimaryBrush}" Cursor="Hand" Margin="0,0,0,24" />

                    <TextBlock Text="Temp Downloads Directory" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                            <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding DownloadTempPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                        </Border>
                        <Button Grid.Column="1" Command="{Binding BrowseDownloadPathCommand}" Content="📁 Browse" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>
                    </Grid>

                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

