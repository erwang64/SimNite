<UserControl x:Class="SimNite.Views.CameraView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <TextBlock Margin="6,0,0,12" Style="{StaticResource TitleTextStyle}" Text="Custom Cameras Backup" />

        <Grid Grid.Row="1" Margin="6,0,6,16">
            <StackPanel MaxWidth="800" HorizontalAlignment="Left">
                <!-- Backup Section -->
                <Border Padding="24" Background="{StaticResource SimNitePanelBrush}" CornerRadius="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Backup SimObjects" Foreground="{StaticResource SimNiteTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Save your custom camera views and panel states into a single clean ZIP file." 
                                   Foreground="{StaticResource SimNiteMutedBrush}" TextWrapping="Wrap" FontSize="14" LineHeight="24" Margin="0,0,0,24"/>

                        <!-- Source MSFS SimObjects -->
                        <TextBlock Text="MSFS SimObjects Source Folder" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding SimObjectsPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            </Border>
                            <Button Grid.Column="1" Command="{Binding BrowseSimObjectsCommand}" Content="📁 Browse" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Border Background="{StaticResource SimNiteSurfaceBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="8" Padding="16" Margin="0,0,0,16">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto" />
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="📷" FontSize="32" Margin="0,0,16,0" VerticalAlignment="Center"/>
                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                    <TextBlock Text="Detected Custom Camera Files" Foreground="{StaticResource SimNiteMutedBrush}" FontSize="13" Margin="0,0,0,4"/>
                                    <TextBlock Text="{Binding CameraCount, StringFormat='{}{0} aircraft profiles found'}" Foreground="{StaticResource SimNiteTextBrush}" FontSize="18" FontWeight="Bold"/>
                                </StackPanel>
                                <Button Grid.Column="2" Command="{Binding RefreshCountCommand}" Content="Refresh" Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteMutedBrush}" Padding="12,0" VerticalAlignment="Center"/>
                            </Grid>
                        </Border>

                        <!-- Destination -->
                        <TextBlock Text="Backup Destination Folder" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding BackupDestinationPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            </Border>
                            <Button Grid.Column="1" Command="{Binding BrowseBackupPathCommand}" Content="📁 Browse" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Button Style="{StaticResource PrimaryButtonStyle}" Command="{Binding BackupCommand}" Content="Create Backup ZIP" Height="44" FontSize="15" HorizontalAlignment="Left" Padding="32,0" />
                    </StackPanel>
                </Border>

                <!-- Restore Section -->
                <Border Padding="24" Background="{StaticResource SimNitePanelBrush}" CornerRadius="12" Margin="0,0,0,16">
                    <StackPanel>
                        <TextBlock Text="Restore SimObjects" Foreground="{StaticResource SimNiteTextBrush}" FontSize="20" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <TextBlock Text="Reinject your customized cameras and views back into MSFS from an existing backup." 
                                   Foreground="{StaticResource SimNiteMutedBrush}" TextWrapping="Wrap" FontSize="14" LineHeight="24" Margin="0,0,0,24"/>

                        <TextBlock Text="Backup ZIP File" Foreground="{StaticResource SimNiteMutedBrush}" Margin="0,0,0,4" />
                        <Grid Margin="0,0,0,24">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="1" CornerRadius="6,0,0,6" Height="40">
                                <TextBox Background="Transparent" BorderThickness="0" Foreground="{StaticResource SimNiteTextBrush}" VerticalContentAlignment="Center" Padding="12,0" Text="{Binding RestoreZipPath, UpdateSourceTrigger=PropertyChanged}" IsReadOnly="True" />
                            </Border>
                            <Button Grid.Column="1" Command="{Binding BrowseRestoreZipCommand}" Content="📁 Browse File" Background="{StaticResource SimNiteInputHoverBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" BorderThickness="0,1,1,1" Foreground="{StaticResource SimNiteTextBrush}" Padding="16,0" Cursor="Hand">
                                <Button.Template>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="0,6,6,0">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Button.Template>
                            </Button>
                        </Grid>

                        <Button Command="{Binding RestoreCommand}" Content="Restore into MSFS" Height="44" FontSize="15" HorizontalAlignment="Left" Background="{StaticResource SimNiteInputBrush}" BorderBrush="{StaticResource SimNiteBorderBrush}" Foreground="{StaticResource SimNiteTextBrush}" Padding="32,0" />
                    </StackPanel>
                </Border>

                <!-- Status Feedback -->
                <TextBlock Text="{Binding StatusMessage}" Foreground="{StaticResource SimNitePrimaryBrush}" FontSize="14" FontWeight="SemiBold" Margin="4,0,0,0"/>

            </StackPanel>
        </Grid>
    </Grid>
</UserControl>